// -*- c -*-

// This is a line comment.

/*
 * This is a block comment.
 */

let g1: i32;
let g2: i32[4];

let g3: i8 = 3;
let g4: i16 = 4;
let g5: i32 = 5;
let g6: i64 = 6;

let g7: i32* = &g5;
let g8: i8* = "abc";
let g9: i32[3] = {0, 1, 2};
let g10: i32*[] = {"foo", "bar"};

let g11: struct {a: i8, b: i32}[2] = {{1, 2}, {3, 4}};
let g12: struct {a: i32[2] }[2] = {{{1, 2}}, {{3, 4}}};
let g13: struct {a: i32[2] }[2] = {{1, 2}, 3, 4};
let g14: struct {a: i32[2] }[2] = {1, 2, 3, 4};

let g15: i8* = {"foo"};
let g16: i8[][4] = {'f', 'o', 'o', 0, 'b', 'a', 'r', 0};
let g17: i8[] = "foobar";
let g18: i8[10] = "foobar";
let g19: i8[3] = "foobar";
let g20: i8* = g17 + 0;
let g21: i8* = g17 + 3;
let g22: i8* = g17 - 3;

let g23: i32  = 3;
let g24: i32* = &g23; 

fun assert (expected: i64, actual: i64, code: i8*) i32 {
    if (expected == actual) {
        printf ("%s => %ld\n", code, actual);
    } else {
        printf ("%s => %ld expected but got %ld\n", code, expected, actual);
        exit (1);
    }
}

fun ret3 () i32 {
    return 3;
    return 5;
}

fun add2 (x: i32, y: i32) i32 {
    return x + y;
}

fun sub2 (x: i32, y: i32) i32 {
    return x - y;
}

fun add6 (a: i32, b: i32, c: i32, d: i32, e: i32, f: i32) i32 {
    return a + b + c + d + e + f;
}

fun addx (x: i32*, y: i32) i32 {
    return *x + y;
}

fun sub_char (a: i8, b: i8, c: i8) i32 {
    return a - b - c;
}

fun sub_short (a: i16, b: i16, c: i16) i32 {
    return a - b - c;
}

fun sub_long (a: i64, b: i64, c: i64) i32 {
    return a - b - c;
}

fun g1_ptr () i32* {
    return &g1;
}

fun fib (x: i32) i32 {
    if (x <= 1) return 1;

    return fib (x - 1) + fib (x - 2);
}

fun count () i32 {
    let cnt: static i32;
    cnt = cnt + 1;
    return cnt;
}


fun param_decay (x: i32[]) i32 {
    return x[0];
}

fun nonefun () none {}

fun main() i32 {

  assert(8, ({ let a: i32=3; let z: i32=5; a+z; }), "let a: i32=3; let z: i32=5; a+z;");

  assert(0, 0, "0");
  assert(42, 42, "42");
  assert(5, 5, "0");
  assert(41,  12 + 34 - 5 , " 12 + 34 - 5 ");
  assert(5, 5, "0");
  assert(15, 5*(9-6), "5*(9-6)");
  assert(4, (3+5)/2, "(3+5)/2");
  assert(-10, -10, "0");
  assert(10, - -10, "- -10");
  assert(10, - - +10, "- - +10");

  assert(0, 0==1, "0==1");
  assert(1, 42==42, "42==42");
  assert(1, 0!=1, "0!=1");
  assert(0, 42!=42, "42!=42");

  assert(1, 0<1, "0<1");
  assert(0, 1<1, "1<1");
  assert(0, 2<1, "2<1");
  assert(1, 0<=1, "0<=1");
  assert(1, 1<=1, "1<=1");
  assert(0, 2<=1, "2<=1");

  assert(1, 1>0, "1>0");
  assert(0, 1>1, "1>1");
  assert(0, 1>2, "1>2");
  assert(1, 1>=0, "1>=0");
  assert(1, 1>=1, "1>=1");
  assert(0, 1>=2, "1>=2");

  assert(3, ({ let a: i32; a=3; a; }), "let a: i32; a=3; a;");
  assert(8, ({ let a: i32; let z: i32; a=3; z=5; a+z; }), "let a: i32; let z: i32; a=3; z=5; a+z;");
  assert(3, ({ let a: i32=3; a; }), "let a: i32=3; a;");
  assert(8, ({ let a: i32=3; let z: i32=5; a+z; }), "let a: i32=3; let z: i32=5; a+z;");

  assert(3, ({ let foo: i32=3; foo; }), "let foo: i32=3; foo;");
  assert(8, ({ let foo123: i32=3; let bar: i32=5; foo123+bar; }), "let foo123: i32=3; let bar: i32=5; foo123+bar;");

  assert(3, ret3(), "ret3();");

  assert(3, ({ let x: i32=0; if (0) x=2; else x=3; x; }), "let x: i32=0; if (0) x=2; else x=3; x;");
  assert(3, ({ let x: i32=0; if (1-1) x=2; else x=3; x; }), "let x: i32=0; if (1-1) x=2; else x=3; x;");
  assert(2, ({ let x: i32=0; if (1) x=2; else x=3; x; }), "let x: i32=0; if (1) x=2; else x=3; x;");
  assert(2, ({ let x: i32=0; if (2-1) x=2; else x=3; x; }), "let x: i32=0; if (2-1) x=2; else x=3; x;");

  assert(3, ({ 1; {2;} 3; }), "1; {2;} 3;");
  assert(10, ({ let i: i32=0; i=0; while(i<10) i=i+1; i; }), "let i: i32=0; i=0; while(i<10) i=i+1; i;");
  assert(55, ({ let i: i32=0; let j: i32=0; while(i<=10) {j=i+j; i=i+1;} j; }), "let i: i32=0; let j: i32=0; while(i<=10) {j=i+j; i=i+1;} j;");
  assert(55, ({ let i: i32=0; let j: i32=0; for (i=0; i<=10; i=i+1) j=i+j; j; }), "let i: i32=0; let j: i32=0; for (i=0; i<=10; i=i+1) j=i+j; j;");

  assert(8, add2(3, 5), "add(3, 5)");
  assert(2, sub2(5, 3), "sub(5, 3)");
  assert(21, add6(1,2,3,4,5,6), "add6(1,2,3,4,5,6)");
  assert(55, fib(9), "fib(9)");

  assert(3, ({ let x: i32=3; *&x; }), "let x: i32=3; *&x;");
  assert(3, ({ let x: i32=3; let y: i32*  = &x; let z: i32** = &y; **z; }), "let x: i32=3; let y: i32* =&x; let z: i32**=&y; **z;");
  assert(5, ({ let x: i32=3; let y: i32 =5; *(&x+1); }), "let x: i32=3; let y: i32 =5; *(&x+1);");
  assert(5, ({ let x: i32=3; let y: i32 =5; *(1+&x); }), "let x: i32=3; let y: i32 =5; *(1+&x);");
  assert(3, ({ let x: i32=3; let y: i32 =5; *(&y-1); }), "let x: i32=3; let y: i32 =5; *(&y-1);");
  assert(5, ({ let x: i32=3; let y: i32 =5; let z: i32* =&x; *(z+1); }), "let x: i32=3; let y: i32 =5; let z: i32* =&x; *(z+1);");
  assert(3, ({ let x: i32=3; let y: i32 =5; let z: i32* =&y; *(z-1); }), "let x: i32=3; let y: i32 =5; let z: i32* =&y; *(z-1);");
  assert(5, ({ let x: i32=3; let y: i32*  =&x; *y=5; x; }), "let x: i32=3; let y: i32* =&x; *y=5; x;");
  assert(7, ({ let x: i32=3; let y: i32 =5; *(&x+1)=7; y; }), "let x: i32=3; let y: i32 =5; *(&x+1)=7; y;");
  assert(7, ({ let x: i32=3; let y: i32 =5; *(&y-1)=7; x; }), "let x: i32=3; let y: i32 =5; *(&y-1)=7; x;");
  assert(8, ({ let x: i32=3; let y: i32 =5; addx(&x, y); }), "let x: i32=3; let y: i32 =5; addx(&x, y);");

  assert(3, ({ let x: i32[2]; let y: i32*  =&x; *y=3; *x; }), "let x: i32[2]; let y: i32* =&x; *y=3; *x;");

  assert(3, ({ let x: i32[3]; *x=3; *(x+1)=4; *(x+2)=5; *x; }), "let x: i32[3]; *x=3; *(x+1)=4; *(x+2)=5; *x;");
  assert(4, ({ let x: i32[3]; *x=3; *(x+1)=4; *(x+2)=5; *(x+1); }), "let x: i32[3]; *x=3; *(x+1)=4; *(x+2)=5; *(x+1);");
  assert(5, ({ let x: i32[3]; *x=3; *(x+1)=4; *(x+2)=5; *(x+2); }), "let x: i32[3]; *x=3; *(x+1)=4; *(x+2)=5; *(x+2);");

  assert(0, ({ let x: i32[2][3]; let y: i32* =x; *y=0; **x; }), "let x: i32[2][3]; let y: i32* =x; *y=0; **x;");
  assert(1, ({ let x: i32[2][3]; let y: i32* =x; *(y+1)=1; *(*x+1); }), "let x: i32[2][3]; let y: i32* =x; *(y+1)=1; *(*x+1);");
  assert(2, ({ let x: i32[2][3]; let y: i32* =x; *(y+2)=2; *(*x+2); }), "let x: i32[2][3]; let y: i32* =x; *(y+2)=2; *(*x+2);");
  assert(3, ({ let x: i32[2][3]; let y: i32* =x; *(y+3)=3; **(x+1); }), "let x: i32[2][3]; let y: i32* =x; *(y+3)=3; **(x+1);");
  assert(4, ({ let x: i32[2][3]; let y: i32* =x; *(y+4)=4; *(*(x+1)+1); }), "let x: i32[2][3]; let y: i32* =x; *(y+4)=4; *(*(x+1)+1);");
  assert(5, ({ let x: i32[2][3]; let y: i32* =x; *(y+5)=5; *(*(x+1)+2); }), "let x: i32[2][3]; let y: i32* =x; *(y+5)=5; *(*(x+1)+2);");
  assert(6, ({ let x: i32[2][3]; let y: i32* =x; *(y+6)=6; **(x+2); }), "let x: i32[2][3]; let y: i32* =x; *(y+6)=6; **(x+2);");

  assert(3, ({ let x: i32[3]; *x=3; x[1]=4; x[2]=5; *x; }), "let x: i32[3]; *x=3; x[1]=4; x[2]=5; *x;");
  assert(4, ({ let x: i32[3]; *x=3; x[1]=4; x[2]=5; *(x+1); }), "let x: i32[3]; *x=3; x[1]=4; x[2]=5; *(x+1);");
  assert(5, ({ let x: i32[3]; *x=3; x[1]=4; x[2]=5; *(x+2); }), "let x: i32[3]; *x=3; x[1]=4; x[2]=5; *(x+2);");
  assert(5, ({ let x: i32[3]; *x=3; x[1]=4; x[2]=5; *(x+2); }), "let x: i32[3]; *x=3; x[1]=4; x[2]=5; *(x+2);");
  assert(5, ({ let x: i32[3]; *x=3; x[1]=4; 2[x]=5; *(x+2); }), "let x: i32[3]; *x=3; x[1]=4; 2[x]=5; *(x+2);");

  assert(0, ({ let x: i32[2][3]; let y: i32* =x; y[0]=0; x[0][0]; }), "let x: i32[2][3]; let y: i32* =x; y[0]=0; x[0][0];");
  assert(1, ({ let x: i32[2][3]; let y: i32* =x; y[1]=1; x[0][1]; }), "let x: i32[2][3]; let y: i32* =x; y[1]=1; x[0][1];");
  assert(2, ({ let x: i32[2][3]; let y: i32* =x; y[2]=2; x[0][2]; }), "let x: i32[2][3]; let y: i32* =x; y[2]=2; x[0][2];");
  assert(3, ({ let x: i32[2][3]; let y: i32* =x; y[3]=3; x[1][0]; }), "let x: i32[2][3]; let y: i32* =x; y[3]=3; x[1][0];");
  assert(4, ({ let x: i32[2][3]; let y: i32* =x; y[4]=4; x[1][1]; }), "let x: i32[2][3]; let y: i32* =x; y[4]=4; x[1][1];");
  assert(5, ({ let x: i32[2][3]; let y: i32* =x; y[5]=5; x[1][2]; }), "let x: i32[2][3]; let y: i32* =x; y[5]=5; x[1][2];");
  assert(6, ({ let x: i32[2][3]; let y: i32* =x; y[6]=6; x[2][0]; }), "let x: i32[2][3]; let y: i32* =x; y[6]=6; x[2][0];");

  assert(4, ({ let x: i32; sizeof(x); }), "let x: i32; sizeof(x);");
  assert(4, ({ let x: i32; sizeof x; }), "let x: i32; sizeof x;");
  assert(8, ({ let x: i32*; sizeof(x); }), "let x: i32*; sizeof(x);");
  assert(16, ({ let x: i32[4]; sizeof(x); }), "let x: i32[4]; sizeof(x);");
  assert(48, ({ let x: i32[3][4]; sizeof(x); }), "let x: i32[3][4]; sizeof(x);");
  assert(16, ({ let x: i32[3][4]; sizeof(*x); }), "let x: i32[3][4]; sizeof(*x);");
  assert(4, ({ let x: i32[3][4]; sizeof(**x); }), "let x: i32[3][4]; sizeof(**x);");
  assert(5, ({ let x: i32[3][4]; sizeof(**x) + 1; }), "let x: i32[3][4]; sizeof(**x) + 1;");
  assert(5, ({ let x: i32[3][4]; sizeof **x + 1; }), "let x: i32[3][4]; sizeof **x + 1;");
  assert(4, ({ let x: i32[3][4]; sizeof(**x + 1); }), "let x: i32[3][4]; sizeof(**x + 1);");

  assert(0, g1, "g1");
  g1=3;
  assert(3, g1, "g1");

  g2[0]=0; g2[1]=1; g2[2]=2; g2[3]=3;
  assert(0, g2[0], "g2[0]");
  assert(1, g2[1], "g2[1]");
  assert(2, g2[2], "g2[2]");
  assert(3, g2[3], "g2[3]");

  assert(4, sizeof(g1), "sizeof(g1)");
  assert(16, sizeof(g2), "sizeof(g2)");

  assert(1, ({ let x: i8 =1; x; }), "let x: i8 =1; x;");
  assert(1, ({ let x: i8 =1; let y: i8 =2; x; }), "let x: i8 =1; let y: i8 =2; x;");
  assert(2, ({ let x: i8 =1; let y: i8 =2; y; }), "let x: i8 =1; let y: i8 =2; y;");

  assert(1, ({ let x: i8; sizeof(x); }), "let x: i8; sizeof(x);");
  assert(10, ({ let x: i8[10]; sizeof(x); }), "let x: i8[10]; sizeof(x);");
  assert(1, sub_char(7, 3, 3), "sub_char(7, 3, 3)");

  assert(97, "abc"[0], "\"abc\"[0]");
  assert(98, "abc"[1], "\"abc\"[1]");
  assert(99, "abc"[2], "\"abc\"[2]");
  assert(0, "abc"[3], "\"abc\"[3]");
  assert(4, sizeof("abc"), "sizeof(\"abc\")");

  assert(7, "\a"[0], "\"\\a\"[0]");
  assert(8, "\b"[0], "\"\\b\"[0]");
  assert(9, "\t"[0], "\"\\t\"[0]");
  assert(10, "\n"[0], "\"\\n\"[0]");
  assert(11, "\v"[0], "\"\\v\"[0]");
  assert(12, "\f"[0], "\"\\f\"[0]");
  assert(13, "\r"[0], "\"\\r\"[0]");
  assert(27, "\e"[0], "\"\\e\"[0]");
  assert(0, "\0"[0], "\"\\0\"[0]");

  assert(106, "\j"[0], "\"\\j\"[0]");
  assert(107, "\k"[0], "\"\\k\"[0]");
  assert(108, "\l"[0], "\"\\l\"[0]");

  assert(2, ({ let x: i32=2; { let x: i32=3; } x; }), "let x: i32=2; { let x: i32=3; } x;");
  assert(2, ({ let x: i32=2; { let x: i32=3; } let y: i32 =4; x; }), "let x: i32=2; { let x: i32=3; } let y: i32 =4; x;");
  assert(3, ({ let x: i32=2; { x=3; } x; }), "let x: i32=2; { x=3; } x;");

  assert(1, ({ let x: struct {a: i32, b: i32}; x.a=1; x.b=2; x.a; }), "let x: struct {a: i32, b: i32}; x.a=1; x.b=2; x.a;");
  assert(2, ({ let x: struct {a: i32, b: i32}; x.a=1; x.b=2; x.b; }), "let x: struct {a: i32, b: i32}; x.a=1; x.b=2; x.b;");
  assert(1, ({ let x: struct {a: i8, b: i32, c: i8}; x.a=1; x.b=2; x.c=3; x.a; }), "let x: struct {a: i8, b: i32, c: i8}; x.a=1; x.b=2; x.c=3; x.a;");
  assert(2, ({ let x: struct {a: i8, b: i32, c: i8}; x.b=1; x.b=2; x.c=3; x.b; }), "let x: struct {a: i8, b: i32, c: i8}; x.b=x; x.a=2; x.b=3; x.b;");
  assert(3, ({ let x: struct {a: i8, b: i32, c: i8}; x.a=1; x.b=2; x.c=3; x.c; }), "let x: struct {a: i8, b: i32, c: i8}; x.a=1; x.b=2; x.c=3; x.c;");

  assert(0, ({ let x: struct {a: i32, b: i32}[3]; let p: i32* =x; p[0]=0; x[0].a; }), "let x: struct {a: i32, b: i32}[3]; let p: i32* =x; p[0]=0; x[0].a;");
  assert(1, ({ let x: struct {a: i32, b: i32}[3]; let p: i32* =x; p[1]=1; x[0].b; }), "let x: struct {a: i32, b: i32}[3]; let p: i32* =x; p[1]=1; x[0].b;");
  assert(2, ({ let x: struct {a: i32, b: i32}[3]; let p: i32* =x; p[2]=2; x[1].a; }), "let x: struct {a: i32, b: i32}[3]; let p: i32* =x; p[2]=2; x[1].a;");
  assert(3, ({ let x: struct {a: i32, b: i32}[3]; let p: i32* =x; p[3]=3; x[1].b; }), "let x: struct {a: i32, b: i32}[3]; let p: i32* =x; p[3]=3; x[1].b;");

  assert(6, ({ let x: struct {a: i32[3], b: i32[5]}; let p: i32* =&x; x.a[0]=6; p[0]; }), "let x: struct {a: i32[3], b: i32[5]}; let p: i32* =&x; x.a[0]=6; p[0];");
  assert(7, ({ let x: struct {a: i32[3], b: i32[5]}; let p: i32* =&x; x.b[0]=7; p[3]; }), "let x: struct {a: i32[3], b: i32[5]}; let p: i32* =&x; x.b[0]=7; p[3];");

  assert(6, ({ let x: struct { a: struct { b: i32 } }; x.a.b=6; x.a.b; }), "let x: struct { a: struct { b: i32 } }; x.a.b=6; x.a.b;");

  assert(4,  ({ let x: struct {a: i32}; sizeof(x); }), "let x: struct {a: i32}; sizeof(x);");
  assert(8,  ({ let x: struct {a: i32, b: i32}; sizeof(x); }), "let x: struct {a: i32, b: i32}; sizeof(x);");
  assert(12, ({ let x: struct {a: i32[3]}; sizeof(x); }), "let x: struct {a: i32[3]}; sizeof(x);");
  assert(16, ({ let x: struct {a: i32}[4]; sizeof(x); }), "let x: struct {a: i32}[4]; sizeof(x);");
  assert(24, ({ let x: struct {a: i32[3]}[2]; sizeof(x); }), "let x: struct {a: i32[3]}[2]; sizeof(x)};");
  assert(2,  ({ let x: struct {a: i8, b: i8}; sizeof(x); }), "let x: struct {a: i8, b: i8}; sizeof(x);");
  assert(8,  ({ let x: struct {a: i8, b: i32}; sizeof(x); }), "let x: struct {a: i8, b: i32}; sizeof(x);");
  assert(8,  ({ let x: struct {a: i32, b: i8}; sizeof(x); }), "let x: struct {a: i32; b: i8}; sizeof(x);");

  assert(7, ({ let x: i32; let y: i8 ; let a: i32=&x; let b: i32 =&y; b-a; }), "let x: i32; let y: i8 ; let a: i32=&x; let b: i32 =&y; b-a;");
  assert(1, ({ let x: i8; let y: i32 ; let a: i32=&x; let b: i32 =&y; b-a; }), "let x: i8; let y: i32 ; let a: i32=&x; let b: i32 =&y; b-a;");

  assert(2, ({ let x: i16; sizeof(x); }), "let x: i16; sizeof(x);");
  assert(4, ({ let x: struct {a: i8, b: i16}; sizeof(x); }), "let x: struct {a: i8, b: i16}; sizeof(x);");

  assert(8, ({ let x: i64; sizeof(x); }), "let x: i64; sizeof(x);");
  assert(16, ({ let x: struct {a: i8, b: i64}; sizeof(x); }), "struct {char a; long b} x; sizeof(x);");

  assert(1, sub_short(7, 3, 3), "sub_short(7, 3, 3)");
  assert(1, sub_long(7, 3, 3), "sub_long(7, 3, 3)");

  assert(24, ({ let x: i32*[3]; sizeof(x); }), "let x: i32*[3]; sizeof(x);");
  assert(8, ({ let x: i32 (*)[3]; sizeof(x); }), "let x: i32 (*)[3]; sizeof(x);");
  assert(3, ({ let x: i32*[3]; let y: i32 ; x[0]=&y; y=3; x[0][0]; }), "let x: i32*[3]; let y: i32 ; x[0]=&y; y=3; x[0][0];");
  assert(4, ({ let x: i32[3]; let y: i32 (*)[3]=x; y[0][0]=4; y[0][0]; }), "let x: i32[3]; let y: i32(*)[3]=x; y[0][0]=4; y[0][0];");

  assert(3, *g1_ptr(), "*g1_ptr()");

  { let x: none*; }

  assert(0, ({ let x: bool = 0; x; }), "let x: bool = 0; x;");
  assert(1, ({ let x: bool = 1; x; }), "let x: bool = 1; x;");
  assert(1, ({ let x: bool = 2; x; }), "let x: bool = 2; x;");

  assert(1, ({ let x: i8; sizeof(x); }), "let x: i8; sizeof(x);");
